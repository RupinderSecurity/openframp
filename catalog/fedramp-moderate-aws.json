  "controls": [
    {
      "control_id": "AC-2",
      "title": "Account Management",
      "family": "Access Control",
      "frameworks": ["FedRAMP AC-2", "PCI DSS 8.1", "SOC 2 CC6.1"],
      "checks": [
        {
          "check_id": "ac-2-iam-user-activity",
          "description": "IAM users should have recent activity or be disabled",
          "severity": "medium",
          "query": "select name, password_last_used, create_date from aws_iam_user",
          "resource_type": "aws_iam_user",
          "fedramp_20x_ksi": ["KSI-IAM-07"]
        },
        {
          "check_id": "ac-2-no-root-access-keys",
          "description": "Root account should not have access keys",
          "severity": "critical",
          "query": "select account_access_keys_present from aws_iam_account_summary",
          "resource_type": "aws_iam_account_summary",
          "fedramp_20x_ksi": ["KSI-IAM-04", "KSI-IAM-05"]
        },
        {
          "check_id": "ac-2-unused-credentials",
          "description": "Credentials unused for 90+ days should be disabled",
          "severity": "medium",
          "query": "select user_name, access_key_id, status, access_key_last_used_date from aws_iam_access_key where status = 'Active'",
          "resource_type": "aws_iam_access_key",
          "fedramp_20x_ksi": ["KSI-IAM-07"]
        }
      ]
    },
    {
      "control_id": "AC-3",
      "title": "Access Enforcement",
      "family": "Access Control",
      "frameworks": ["FedRAMP AC-3", "PCI DSS 7.2", "SOC 2 CC6.1"],
      "checks": [
        {
          "check_id": "ac-3-s3-no-public-access",
