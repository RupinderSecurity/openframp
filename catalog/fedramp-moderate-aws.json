        {
          "check_id": "ac-3-s3-no-public-policy",
          "description": "S3 buckets should not have public bucket policies",
          "severity": "high",
          "query": "select name, bucket_policy_is_public from aws_s3_bucket where bucket_policy_is_public = true",
          "resource_type": "aws_s3_bucket",
          "fedramp_20x_ksi": ["KSI-CNA-02", "KSI-IAM-05"]
        },
        {
          "check_id": "ac-3-rds-no-public-access",
          "description": "RDS instances should not be publicly accessible",
          "severity": "critical",
          "query": "select db_instance_identifier, publicly_accessible from aws_rds_db_instance where publicly_accessible = true",
          "resource_type": "aws_rds_db_instance",
          "fedramp_20x_ksi": ["KSI-CNA-02"]
        },
        {
          "check_id": "ac-3-redshift-no-public",
          "description": "Redshift clusters should not be publicly accessible",
          "severity": "critical",
          "query": "select cluster_identifier, publicly_accessible from aws_redshift_cluster where publicly_accessible = true",
          "resource_type": "aws_redshift_cluster",
          "fedramp_20x_ksi": ["KSI-CNA-02"]
        }
